{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist/",
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "rootDir": "../.."
  },
  "include": [
    "./src/*.ts",
    "./src/*.tsx",
    "../../../spytial-core/src/components/ErrorMessageModal/*.ts",
    "../../../spytial-core/src/components/ErrorMessageModal/*.tsx",
    "../../../spytial-core/src/layout/constraint-validator.ts",
    "../../../spytial-core/src/layout/constraint-types.ts"
  ]
}
